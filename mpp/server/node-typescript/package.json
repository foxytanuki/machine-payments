{
  "name": "mpp-rest-node-typescript",
  "private": true,
  "type": "module",
  "description": "MPP REST API sample with Stripe Payment Tokens using Hono",
  "scripts": {
    "dev": "dotenvx run -f ../../../.env -- tsx main.ts",
    "client": "dotenvx run -f ../../../.env -- tsx client.ts",
    "payment:simulate": "dotenvx run -f ../../../.env -- tsx simulate-crypto-deposit.ts",
    "wallet:address": "dotenvx run -f ../../../.env -- tsx wallet.ts address",
    "wallet:fund": "dotenvx run -f ../../../.env -- tsx wallet.ts fund",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.0",
    "hono": "^4.12.15",
    "mppx": "^0.6.15",
    "node-cache": "^5.1.2",
    "stripe": "^22.1.0",
    "viem": "^2.48.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.2",
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
